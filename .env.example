# =============================================================================
# .env.example — Speech-to-Text API  Environment Variables
#
# Copy this file to .env and fill in real values.
# On Colab: run  export VARIABLE=value  in a code cell before starting the API.
# In Docker: pass via docker-compose environment: section (already wired in
#            docker-compose.yml) or a --env-file flag.
#
# Priority:  ENV VAR  >  config.yaml  >  code defaults
#
# WhisperX install (run AFTER all other packages):
#   pip install --no-deps git+https://github.com/m-bain/whisperX.git@v3.8.5
# =============================================================================

# ---------------------------------------------------------------------------
# Redis
# Default: redis://localhost:6379/0
# Docker:  redis://redis:6379/0   (the docker-compose service name)
# Colab:   redis://localhost:6379/0  (redis-server started by colab_setup.sh)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------
# Whisper model size: tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL_SIZE=large-v2

# Compute device: cuda | cpu
WHISPER_DEVICE=cuda

# Compute precision: float16 (GPU) | int8 (CPU / low-VRAM) | float32
WHISPER_COMPUTE_TYPE=float16

# Where to cache downloaded model weights.
# Colab: use /content/models so weights survive kernel restarts on the same VM.
WHISPER_DOWNLOAD_ROOT=./models

# ---------------------------------------------------------------------------
# Performance
# ---------------------------------------------------------------------------
# CTranslate2 batch size (number of tokens fed at once). Reduce if OOM.
WHISPER_BATCH_SIZE=16

# Number of parallel transcription threads per worker. Keep 1 on single GPU.
WHISPER_MAX_WORKERS=1

# Maximum audio chunk length in seconds before splitting.
WHISPER_CHUNK_DURATION=30

# Enable Silero-VAD based chunking: 1 | true | yes
WHISPER_USE_VAD=true

# ---------------------------------------------------------------------------
# Accuracy
# ---------------------------------------------------------------------------
WHISPER_BEAM_SIZE=5
WHISPER_TEMPERATURE=0.0
WHISPER_BEST_OF=5

# ---------------------------------------------------------------------------
# Speaker diarization  (NVIDIA NeMo)
#
# NeMo downloads models from NVIDIA NGC automatically — no HuggingFace
# token required.  Models: vad_multilingual_marblenet, titanet_large,
# diar_msdd_telephonic.
#
# First run downloads ~2 GB to ~/.cache/nemo (or NEMO_CACHE_DIR).
# ---------------------------------------------------------------------------
WHISPER_DIARIZATION_ENABLED=true

# ---------------------------------------------------------------------------
# Webhook delivery
# ---------------------------------------------------------------------------
WHISPER_WEBHOOK_ENABLED=true
WHISPER_WEBHOOK_TIMEOUT=15
WHISPER_WEBHOOK_RETRY_COUNT=3

# ---------------------------------------------------------------------------
# API Security
#
# Set WHISPER_API_KEY_ENABLED=false to disable auth (development only!).
# WHISPER_API_KEYS accepts a comma-separated list of valid keys.
# ---------------------------------------------------------------------------
WHISPER_API_KEY_ENABLED=true
WHISPER_API_KEYS=change-me-key-1,change-me-key-2

# ---------------------------------------------------------------------------
# File system paths (absolute paths recommended on Colab)
# ---------------------------------------------------------------------------
WHISPER_UPLOAD_DIR=./uploads
WHISPER_OUTPUT_DIR=./outputs
WHISPER_TEMP_DIR=./temp
